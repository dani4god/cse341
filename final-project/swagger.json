{
  "swagger": "2.0",
  "info": {
    "title": "ShopSphere Online Store API",
    "description": "A RESTful API for managing an online shopping platform including products and orders.",
    "version": "1.0.0"
  },
  "host": "https://cse341-ie1j.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "tags": [
    { "name": "Products", "description": "Endpoints for managing products" },
    { "name": "Orders", "description": "Endpoints for managing orders" }
  ],
  "paths": {
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "Get all products",
        "description": "Returns a list of all products in the database.",
        "responses": {
          "200": { "description": "Successfully retrieved all products.", "schema": { "$ref": "#/definitions/ProductsList" } },
          "500": { "description": "Internal server error." }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create a new product",
        "description": "Adds a new product to the database.",
        "parameters": [
          { "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/NewProduct" } }
        ],
        "responses": {
          "201": { "description": "Product created successfully." },
          "400": { "description": "Missing required fields." },
          "500": { "description": "Internal server error." }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get a product by ID",
        "description": "Returns a single product matching the given MongoDB ObjectId.",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "type": "string", "description": "MongoDB ObjectId of the product" }
        ],
        "responses": {
          "200": { "description": "Successfully retrieved the product.", "schema": { "$ref": "#/definitions/Product" } },
          "400": { "description": "Invalid ID format." },
          "404": { "description": "Product not found." },
          "500": { "description": "Internal server error." }
        }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Update a product by ID",
        "description": "Updates an existing product's information.",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "type": "string" },
          { "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/NewProduct" } }
        ],
        "responses": {
          "200": { "description": "Product updated successfully." },
          "400": { "description": "Invalid ID format or missing fields." },
          "404": { "description": "Product not found." },
          "500": { "description": "Internal server error." }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete a product by ID",
        "description": "Permanently removes a product from the database.",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Product deleted successfully." },
          "400": { "description": "Invalid ID format." },
          "404": { "description": "Product not found." },
          "500": { "description": "Internal server error." }
        }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get all orders",
        "description": "Returns a list of all orders in the database.",
        "responses": {
          "200": { "description": "Successfully retrieved all orders.", "schema": { "$ref": "#/definitions/OrdersList" } },
          "500": { "description": "Internal server error." }
        }
      },
      "post": {
        "tags": ["Orders"],
        "summary": "Create a new order",
        "description": "Adds a new order to the database.",
        "parameters": [
          { "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/NewOrder" } }
        ],
        "responses": {
          "201": { "description": "Order created successfully." },
          "400": { "description": "Missing required fields." },
          "500": { "description": "Internal server error." }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get an order by ID",
        "description": "Returns a single order matching the given MongoDB ObjectId.",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "type": "string", "description": "MongoDB ObjectId of the order" }
        ],
        "responses": {
          "200": { "description": "Successfully retrieved the order.", "schema": { "$ref": "#/definitions/Order" } },
          "400": { "description": "Invalid ID format." },
          "404": { "description": "Order not found." },
          "500": { "description": "Internal server error." }
        }
      },
      "put": {
        "tags": ["Orders"],
        "summary": "Update an order by ID",
        "description": "Updates an existing order's information.",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "type": "string" },
          { "in": "body", "name": "body", "required": true, "schema": { "$ref": "#/definitions/NewOrder" } }
        ],
        "responses": {
          "200": { "description": "Order updated successfully." },
          "400": { "description": "Invalid ID format or missing fields." },
          "404": { "description": "Order not found." },
          "500": { "description": "Internal server error." }
        }
      },
      "delete": {
        "tags": ["Orders"],
        "summary": "Delete an order by ID",
        "description": "Permanently removes an order from the database.",
        "parameters": [
          { "in": "path", "name": "id", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Order deleted successfully." },
          "400": { "description": "Invalid ID format." },
          "404": { "description": "Order not found." },
          "500": { "description": "Internal server error." }
        }
      }
    }
  },
  "definitions": {
    "Product": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "60d5ec49f1b2c8b1f8e4e1a1" },
        "name": { "type": "string", "example": "Wireless Headphones" },
        "description": { "type": "string", "example": "High quality wireless headphones" },
        "price": { "type": "number", "example": 99.99 },
        "stock": { "type": "number", "example": 50 },
        "category": { "type": "string", "example": "Electronics" },
        "rating": { "type": "number", "example": 4.5 }
      }
    },
    "NewProduct": {
      "type": "object",
      "required": ["name", "description", "price", "stock", "category", "rating"],
      "properties": {
        "name": { "type": "string", "example": "Wireless Headphones" },
        "description": { "type": "string", "example": "High quality wireless headphones" },
        "price": { "type": "number", "example": 99.99 },
        "stock": { "type": "number", "example": 50 },
        "category": { "type": "string", "example": "Electronics" },
        "rating": { "type": "number", "example": 4.5 }
      }
    },
    "ProductsList": {
      "type": "array",
      "items": { "$ref": "#/definitions/Product" }
    },
    "Order": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "60d5ec49f1b2c8b1f8e4e1a1" },
        "userId": { "type": "string", "example": "60d5ec49f1b2c8b1f8e4e1a2" },
        "products": { "type": "array", "items": { "type": "string" }, "example": ["60d5ec49f1b2c8b1f8e4e1a3"] },
        "totalAmount": { "type": "number", "example": 199.99 },
        "status": { "type": "string", "example": "pending" },
        "paymentMethod": { "type": "string", "example": "credit card" },
        "createdAt": { "type": "string", "example": "2024-01-15" },
        "orderAddress": { "type": "string", "example": "123 Main St, New York, NY" }
      }
    },
    "NewOrder": {
      "type": "object",
      "required": ["userId", "products", "totalAmount", "status", "paymentMethod", "createdAt", "orderAddress"],
      "properties": {
        "userId": { "type": "string", "example": "60d5ec49f1b2c8b1f8e4e1a2" },
        "products": { "type": "array", "items": { "type": "string" }, "example": ["60d5ec49f1b2c8b1f8e4e1a3"] },
        "totalAmount": { "type": "number", "example": 199.99 },
        "status": { "type": "string", "example": "pending" },
        "paymentMethod": { "type": "string", "example": "credit card" },
        "createdAt": { "type": "string", "example": "2024-01-15" },
        "orderAddress": { "type": "string", "example": "123 Main St, New York, NY" }
      }
    },
    "OrdersList": {
      "type": "array",
      "items": { "$ref": "#/definitions/Order" }
    }
  }
}