{
  "swagger": "2.0",
  "info": {
    "title": "Contacts API",
    "description": "A RESTful API for storing and retrieving contact information including friends and work colleagues.",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": ["http", "https"],
  "tags": [
    {
      "name": "Contacts",
      "description": "Endpoints for managing contacts"
    }
  ],
  "paths": {
    "/contacts": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get all contacts",
        "description": "Returns a list of all contacts in the database.",
        "responses": {
          "200": {
            "description": "Successfully retrieved all contacts.",
            "schema": { "$ref": "#/definitions/ContactsList" }
          },
          "500": { "description": "Internal server error." }
        }
      },
      "post": {
        "tags": ["Contacts"],
        "summary": "Create a new contact",
        "description": "Adds a new contact to the database.",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Contact data to create.",
            "required": true,
            "schema": { "$ref": "#/definitions/NewContact" }
          }
        ],
        "responses": {
          "201": { "description": "Contact created successfully." },
          "400": { "description": "Missing required fields." },
          "500": { "description": "Internal server error." }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Get a contact by ID",
        "description": "Returns a single contact matching the given MongoDB ObjectId.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "MongoDB ObjectId of the contact",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved the contact.",
            "schema": { "$ref": "#/definitions/Contact" }
          },
          "400": { "description": "Invalid ID format." },
          "404": { "description": "Contact not found." },
          "500": { "description": "Internal server error." }
        }
      },
      "put": {
        "tags": ["Contacts"],
        "summary": "Update a contact by ID",
        "description": "Updates an existing contact's information.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "MongoDB ObjectId of the contact to update",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Updated contact data.",
            "required": true,
            "schema": { "$ref": "#/definitions/NewContact" }
          }
        ],
        "responses": {
          "200": { "description": "Contact updated successfully." },
          "400": { "description": "Invalid ID format or missing fields." },
          "404": { "description": "Contact not found." },
          "500": { "description": "Internal server error." }
        }
      },
      "delete": {
        "tags": ["Contacts"],
        "summary": "Delete a contact by ID",
        "description": "Permanently removes a contact from the database.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "MongoDB ObjectId of the contact to delete",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": { "description": "Contact deleted successfully." },
          "400": { "description": "Invalid ID format." },
          "404": { "description": "Contact not found." },
          "500": { "description": "Internal server error." }
        }
      }
    }
  },
  "definitions": {
    "Contact": {
      "type": "object",
      "properties": {
        "_id": { "type": "string", "example": "60d5ec49f1b2c8b1f8e4e1a1" },
        "firstName": { "type": "string", "example": "Jane" },
        "lastName": { "type": "string", "example": "Doe" },
        "email": { "type": "string", "example": "jane.doe@example.com" },
        "favoriteColor": { "type": "string", "example": "Blue" },
        "birthday": { "type": "string", "example": "1990-06-15" }
      }
    },
    "NewContact": {
      "type": "object",
      "required": ["firstName", "lastName", "email", "favoriteColor", "birthday"],
      "properties": {
        "firstName": { "type": "string", "example": "Jane" },
        "lastName": { "type": "string", "example": "Doe" },
        "email": { "type": "string", "example": "jane.doe@example.com" },
        "favoriteColor": { "type": "string", "example": "Blue" },
        "birthday": { "type": "string", "example": "1990-06-15" }
      }
    },
    "ContactsList": {
      "type": "array",
      "items": { "$ref": "#/definitions/Contact" }
    }
  }
}
